{
	"name": "modelviewer",
	"description": "3D Geo XML viewer with OpenGL",
	"authors": ["ModelViewer"],
	"license": "MIT",
	"targetPath": "bin",
	"sourcePaths": [
		"source",
		"source/c"
	],
	"dependencies": {
		"bindbc-glfw": "~>0.13.0",
		"bindbc-opengl": "~>0.13.0",
		"bindbc-imgui": "0.7.0",
		"gl3n": "~>1.4.1",
		"dxml": "~>0.4.5"
	},
	"subConfigurations": {
		"bindbc-imgui": "static_dynamicCRT"
	},
	"versions": [
		"GLFW_33",
		"GL_33",
		"USE_GL3"
	],
	"configurations": [
		{
			"name": "application",
			"targetType": "executable",
			"mainSourceFile": "source/app.d",
			"importPaths": [
				"deps/cimgui"
			],
			"excludedSourceFiles": [
				"$PACKAGE_DIR/source/bindbc/imgui/ogl.d"
			],
			"preBuildCommands-linux-x86_64": [
				"g++-13 -c -Ideps/cimgui -o source/c/imgui_helper.o source/c/imgui_helper.cpp"
			],
			"preBuildCommands-windows-x86_64": [
				"scripts\\compile-imgui-helper.bat"
			],
			"sourceFiles-linux-x86_64": [
				"source/c/imgui_helper.o"
			],
			"sourceFiles-windows-x86_64": [
				"source/c/imgui_helper.obj"
			],
			"libs-linux": [
				"sdl2",
				"freetype"
			]
		},
		{
			"name": "parser-test",
			"targetType": "executable",
			"targetName": "parser-test",
			"mainSourceFile": "source/parser_test.d",
			"dependencies": {
				"dxml": "~>0.4.5"
			}
		}
	]
}
