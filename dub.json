{
	"name": "modelviewer",
	"description": "3D Geo XML viewer with OpenGL",
	"authors": ["ModelViewer"],
	"license": "MIT",
	"targetPath": "bin",
	"sourcePaths": [
		"source"
	],
	"dependencies": {
		"dxml": "~>0.4.5"
	},
	"versions": [
		"GL_33",
		"USE_GL3"
	],
	"configurations": [
		{
			"name": "application",
			"targetType": "executable",
			"mainSourceFile": "source/app.d",
			"dependencies": {
				"dlangui": "~>0.10.8",
				"gl3n": "~>1.4.1"
			}
		},
		{
			"name": "parser-test",
			"targetType": "executable",
			"targetName": "parser-test",
			"mainSourceFile": "source/parser_test.d",
			"dependencies": {
				"gl3n": "~>1.4.1"
			},
			"excludedSourceFiles": [
				"source/app.d",
				"source/mesh.d",
				"source/shader.d",
				"source/camera.d",
				"source/axis_gizmo.d",
				"source/axis_label.d",
				"source/skeleton_renderer.d",
				"source/settings.d"
			]
		}
	]
}
